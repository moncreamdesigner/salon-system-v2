Options -Indexes
DirectoryIndex booking.html

# Deploy hiigdsen HTML, CSS, JS-iig browser huuchin cache-aas ashiglahgui.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js)$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>
</IfModule>

RewriteEngine On

# /login/ хаягийг нэг стандарт /login хаяг руу оруулна.
RewriteCond %{THE_REQUEST} \s/+login/[?\s] [NC]
RewriteRule ^login/$ /login [R=302,L]

# Одоогийн салон удирдлагын систем.
RewriteRule ^login$ index.html [L]

